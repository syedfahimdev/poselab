# PoseLab web — environment template
#
# Copy to .env.local if you need to override defaults:
#     cp web/.env.local.example web/.env.local

# Where the FastAPI backend lives. The default (/api-proxy) is a same-origin
# rewrite so dev + production work without CORS or two-URL juggling. Override
# only when running the frontend and backend on different hosts AND you
# really want the browser to hit the backend directly.
NEXT_PUBLIC_API_BASE_URL=/api-proxy

# Public-facing URL of the web app — used to construct share links like
# /p/<slug>. Defaults to localhost.
NEXT_PUBLIC_WEB_BASE_URL=http://localhost:3030

# Supabase — only needed if you want real user accounts via Google / magic
# link. PoseLab works fine without these (anonymous flow + BYOK keys).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Where Next.js's `/api-proxy/*` rewrite forwards requests. Default points at
# localhost:8000 (FastAPI). When deploying both behind a single public URL,
# this stays the same — only the public URL changes.
API_PROXY_TARGET=http://localhost:8000

# Additional dev origins for Next.js 16 (Tailscale hostname, LAN IP, ngrok,
# Codespaces URL, etc.). Comma-separated. Required when accessing the dev
# server from anywhere other than localhost — Next 16 blocks non-localhost
# dev origins by default.
#
# Example:
#     ALLOWED_DEV_ORIGINS=my-laptop.tail9ec012.ts.net,192.168.1.42,abc.ngrok-free.app
ALLOWED_DEV_ORIGINS=
