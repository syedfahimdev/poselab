# PoseLab API — environment template
#
# ALL of these env vars are OPTIONAL. PoseLab is BYOK ("bring your own key"):
# users add their keys via the web UI's Settings panel, and those keys are
# sent as per-request headers. The values here are server-side defaults for
# self-hosters who'd rather configure once than ask each user.
#
# Copy to .env if you want server-side defaults:
#     cp api/.env.example api/.env

# ─── AI providers (text + vision) ────────────────────────────────────────────
# OpenAI-compatible chat-completions endpoint. Default points at OpenRouter
# which proxies to many models including Gemini, Claude, GPT, etc.
#
# Compatible providers (set base URL accordingly):
#   - OpenRouter:  https://openrouter.ai/api/v1   keys at https://openrouter.ai/keys
#   - OpenAI:      https://api.openai.com/v1      keys at https://platform.openai.com/api-keys
#   - LiteLLM:     https://your-litellm.example.com (self-hosted)
#   - Together:    https://api.together.xyz/v1
#   - Groq:        https://api.groq.com/openai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
# Models to use. Format depends on provider:
#   - OpenRouter: "google/gemini-2.5-flash", "anthropic/claude-3-5-sonnet"
#   - OpenAI:     "gpt-4o-mini", "gpt-4o"
AI_VISION_MODEL=google/gemini-2.5-flash
AI_TEXT_MODEL=google/gemini-2.5-flash

# ─── Image generation ────────────────────────────────────────────────────────
# Three providers supported. Configure any one; users can override per-request
# from the Settings panel (BYOK).
#
# 1) Runware (recommended — unified access to gpt-image-2, Flux, Grok, etc.)
#    https://runware.ai
RUNWARE_API_KEY=
RUNWARE_MODEL=openai:gpt-image@2
RUNWARE_IMAGE_SIZE=1024x1024
#
# 2) OpenAI direct (gpt-image-2 — strong identity preservation)
#    https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_SIZE=1024x1024
#
# 3) fal.ai (FLUX Pro Kontext)
#    https://fal.ai/dashboard/keys
FAL_KEY=
FAL_MODEL=fal-ai/flux-pro/kontext
#
# Force one provider: runware | openai | fal | auto (default).
# Auto-resolution order: runware → openai → fal → mock.
IMAGE_PROVIDER=

# ─── Public URL bases (used for share links & file serving) ──────────────────
WEB_BASE_URL=http://localhost:3030
API_BASE_URL=http://localhost:3030/api-proxy

# ─── Supabase (optional — only needed if you want real user accounts) ────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# Local-only dev auth bypass. NEVER set this in production. When set, a
# Bearer token like `dev:user@example.com` returns a fake paid user — useful
# for testing without setting up Supabase. Default-deny.
ALLOW_DEV_AUTH=

# ─── Rate limits (per-day caps; refunded if AI call fails) ───────────────────
LIMIT_ANALYZE_FREE=3
LIMIT_ANALYZE_ANON=3
LIMIT_GENERATE_FREE=0
LIMIT_GENERATE_PAID=100
LIMIT_ANALYZE_PAID=1000

# ─── CORS — comma-separated allowed origins. NEVER use '*' here when running
#       publicly: combined with credentials=true it's a credential-exfil hole.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3030,http://127.0.0.1:3000,http://127.0.0.1:3030

# ─── Storage backend (local | supabase). 'supabase' coming later. ────────────
STORAGE_BACKEND=local

# ─── Production payments + observability (optional) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENTRY_DSN=

# Set to "production" to disable all dev affordances unconditionally.
PYTHON_ENV=
